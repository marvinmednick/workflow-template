#!/usr/bin/env bash
# update-workflow — Pull latest workflow-template updates into this project
#
# Pulls the ~/.workflow-template clone — all symlinked files (commands/, scripts,
# stubs, configs) update instantly since they are symlinks into that clone.
#
# Run from the project root.

set -euo pipefail

REMOTE="https://github.com/marvinmednick/workflow-template"
TEMPLATE="$HOME/.workflow-template"

if [[ ! -d "$TEMPLATE" ]]; then
  echo "Error: ~/.workflow-template not found."
  echo "Run: git clone $REMOTE ~/.workflow-template"
  exit 1
fi

echo "Updating workflow-template clone..."
git -C "$TEMPLATE" pull --quiet
echo "  ✓ All symlinked files up to date (commands/, scripts, stubs, configs)"
