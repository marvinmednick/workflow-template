#!/usr/bin/env bash
# implement — Start an implementation session for a feature or issue spec
#
# Usage: ./implement <ID> [--tool codex|gemini|aider] [--model <model>] [--plan [--force]]
#
#   <ID>          Feature ID (F1) or issue ID (I4 = GitHub issue #4)
#   --plan        Stage 1: write implementation plan only, no code
#   --force       Overwrite existing plan (use with --plan)
#   --tool        codex, gemini, or aider (overrides IMPLEMENT_TOOL env and .implement.conf)
#   --model       Model override (overrides IMPLEMENT_MODEL env and .implement.conf)
#
# Stages:
#   1. Plan:      ./implement F1 --plan
#                 → writes plans/F1-plan.md, then exits
#                 → run /review-plan F1 in Claude Code to review and approve
#   2. Implement: ./implement F1
#                 → if plans/F1-plan-approved.md exists, uses it automatically
#                 → Full-level spec without an approved plan is blocked
#                 → implementor runs tests and fixes failures as part of the session
#   3. Verify:    ./check-tests  (pre-commit sanity check after /review)
#
# All three tools run in interactive mode: codex and gemini accept an initial prompt
# then stay interactive; aider does the same. Type 'continue' to proceed after each response.
#
# Tool selection: --tool arg > IMPLEMENT_TOOL env > .implement.conf > error
# Model selection: --model arg > IMPLEMENT_MODEL env > .implement.conf
#
# For aider, AGENT.md and CODING.md are auto-loaded via .aider.conf.yml.
# For Gemini CLI, AGENT.md and CODING.md are auto-loaded via .gemini/settings.json.
# For Codex, AGENTS.md is auto-loaded; prompt also explicitly requires AGENT.md + CODING.md.
#
# Configuration (in .implement.conf):
#   tool=codex
#   model=gpt-5.4
#   TEST_CMD=npm --prefix client test -- --watchAll=false
#   KNOWN_FILE=client/known-test-failures.txt
#   SPEC_FILE_PATTERN=client|supabase/migrations
#   AIDER_REFERENCE_FILE=client/components/__tests__/MyFile-test.tsx   # optional

set -euo pipefail

SPEC_ID=""
TOOL=""
MODEL=""
PLAN_MODE=false
FORCE=false

while [[ $# -gt 0 ]]; do
  case "$1" in
    [FI][0-9]*)  SPEC_ID="$1"; shift;;
    --tool)      TOOL="$2"; shift 2;;
    --model)     MODEL="$2"; shift 2;;
    --plan)      PLAN_MODE=true; shift;;
    --force)     FORCE=true; shift;;
    -h|--help)
      echo "Usage: ./implement <ID> [--tool codex|gemini|aider] [--model <model>] [--plan [--force]]"
      echo ""
      echo "  ID         F1 (feature) or I4 (issue — matches GitHub issue #4)"
      echo "  --plan     Stage 1: write plan only (no code)"
      echo "  --force    Overwrite existing plan"
      echo ""
      echo "Tool selection (required unless configured):"
      echo "  --tool     codex, gemini, or aider"
      echo "             Overrides: IMPLEMENT_TOOL env var or tool= in .implement.conf"
      echo "  --model    Model to use (e.g. codex-mini-latest, claude-sonnet-4-6)"
      echo "             Overrides: IMPLEMENT_MODEL env var or model= in .implement.conf"
      exit 0;;
    *)
      echo "Unknown argument: $1"
      echo "Usage: ./implement <ID> [--tool codex|gemini|aider] [--model <model>] [--plan [--force]]"
      exit 1;;
  esac
done

if [[ -z "$SPEC_ID" ]]; then
  echo "Usage: ./implement <ID> [--tool codex|gemini|aider] [--model <model>] [--plan [--force]]"
  echo ""
  echo "  ID must be a feature ID (F1) or issue ID (I4)"
  exit 1
fi

# Resolve tool: --tool arg > IMPLEMENT_TOOL env > .implement.conf > error
TOOL_SOURCE=""
CONFIG_FILE=".implement.conf"
CONFIG_TOOL=""
CONFIG_MODEL=""
TEST_CMD=""
KNOWN_FILE=""
SPEC_FILE_PATTERN=""
AIDER_REFERENCE_FILE=""

if [[ -f "$CONFIG_FILE" ]]; then
  CONFIG_TOOL=$(grep '^tool=' "$CONFIG_FILE" | head -1 | sed 's/^tool=//' | tr -d '[:space:]' || true)
  CONFIG_MODEL=$(grep '^model=' "$CONFIG_FILE" | head -1 | sed 's/^model=//' | tr -d '[:space:]' || true)
  TEST_CMD=$(grep '^TEST_CMD=' "$CONFIG_FILE" | head -1 | sed 's/^TEST_CMD=//' || true)
  KNOWN_FILE=$(grep '^KNOWN_FILE=' "$CONFIG_FILE" | head -1 | sed 's/^KNOWN_FILE=//' | tr -d '[:space:]' || true)
  SPEC_FILE_PATTERN=$(grep '^SPEC_FILE_PATTERN=' "$CONFIG_FILE" | head -1 | sed 's/^SPEC_FILE_PATTERN=//' | tr -d '[:space:]' || true)
  AIDER_REFERENCE_FILE=$(grep '^AIDER_REFERENCE_FILE=' "$CONFIG_FILE" | head -1 | sed 's/^AIDER_REFERENCE_FILE=//' | tr -d '[:space:]' || true)
fi

if [[ -z "$TOOL" ]]; then
  if [[ -n "${IMPLEMENT_TOOL:-}" ]]; then
    TOOL="$IMPLEMENT_TOOL"
    TOOL_SOURCE="env"
  elif [[ -n "$CONFIG_TOOL" ]]; then
    TOOL="$CONFIG_TOOL"
    TOOL_SOURCE="config"
  else
    echo "Error: No tool specified."
    echo ""
    echo "Specify one of:"
    echo "  --tool codex|gemini|aider         (CLI argument)"
    echo "  IMPLEMENT_TOOL=codex              (environment variable)"
    echo "  tool=codex in .implement.conf     (project config)"
    exit 1
  fi
else
  TOOL_SOURCE="arg"
fi

# Resolve model: --model arg > IMPLEMENT_MODEL env > .implement.conf
if [[ -z "$MODEL" ]]; then
  if [[ -n "${IMPLEMENT_MODEL:-}" ]]; then
    MODEL="$IMPLEMENT_MODEL"
  elif [[ -n "$CONFIG_MODEL" ]]; then
    MODEL="$CONFIG_MODEL"
  fi
fi

# Validate required config
if [[ -z "$TEST_CMD" ]]; then
  echo "Error: TEST_CMD not set in $CONFIG_FILE"
  echo "Add a line like: TEST_CMD=npm test -- --watchAll=false"
  exit 1
fi
if [[ -z "$KNOWN_FILE" ]]; then
  KNOWN_FILE="known-test-failures.txt"
fi
if [[ -z "$SPEC_FILE_PATTERN" ]]; then
  echo "Error: SPEC_FILE_PATTERN not set in $CONFIG_FILE"
  echo "Add a line like: SPEC_FILE_PATTERN=src|migrations"
  exit 1
fi

# Find the spec file
SPEC_FILE=$(find specs -name "${SPEC_ID}-*.md" 2>/dev/null | head -1)
if [[ -z "$SPEC_FILE" ]]; then
  echo "Error: No spec file found for ${SPEC_ID} in specs/"
  echo "Available specs:"
  ls specs/*.md 2>/dev/null | sed 's/^/  /' || echo "  (none)"
  exit 1
fi

PLAN_FILE="plans/${SPEC_ID}-plan.md"
APPROVED_PLAN_FILE="plans/${SPEC_ID}-plan-approved.md"
PROGRESS_FILE="plans/${SPEC_ID}-progress.md"

# Always ensure plans/ directory exists
mkdir -p plans

# Guard: if a non-empty plan already exists and --force was not passed, stop and guide the user.
if [[ "$PLAN_MODE" == true ]] && [[ "$FORCE" == false ]]; then
  if [[ -f "$PLAN_FILE" ]] && [[ -s "$PLAN_FILE" ]]; then
    echo "Plan already exists: $PLAN_FILE"
    echo ""
    if [[ "$SPEC_FILE" -nt "$PLAN_FILE" ]]; then
      echo "  ⚠  Spec is newer than the plan — the spec may have changed since the plan was written."
      echo "     Consider regenerating with --force to pick up spec changes."
    fi
    echo "Next step:  /review-plan ${SPEC_ID} in Claude Code to review, iterate, and approve."
    echo "Regenerate: ./implement ${SPEC_ID} --plan --force  (overwrites existing plan)"
    exit 0
  fi
fi

# Extract review level from spec header
REVIEW_LEVEL=$(grep -oP '(?<=\*\*Review Level:\*\* )\S+' "$SPEC_FILE" 2>/dev/null | head -1 || true)

# Auto-detect approved plan
HAS_APPROVED_PLAN=false
if [[ -f "$APPROVED_PLAN_FILE" ]]; then
  HAS_APPROVED_PLAN=true
fi

# Enforce: Full-level spec in implement mode requires an approved plan
if [[ "$PLAN_MODE" == false ]] && [[ "$REVIEW_LEVEL" == "Full" ]] && [[ "$HAS_APPROVED_PLAN" == false ]]; then
  echo "Error: ${SPEC_ID} is a Full-level spec and requires an approved plan."
  echo ""
  echo "  Step 1: ./implement ${SPEC_ID} --plan          # write the plan"
  echo "  Step 2: /review-plan ${SPEC_ID}               # review and approve in Claude Code"
  echo "  Step 3: ./implement ${SPEC_ID}                # implement with approved plan"
  exit 1
fi

echo "Spec:  $SPEC_FILE"
echo "Tool:  $TOOL [$TOOL_SOURCE]${MODEL:+ (model: $MODEL)}"
if [[ -n "$REVIEW_LEVEL" ]]; then
  echo "Review Level: $REVIEW_LEVEL"
fi
if [[ "$HAS_APPROVED_PLAN" == true ]] && [[ "$PLAN_MODE" == false ]]; then
  echo "Plan:  $APPROVED_PLAN_FILE (auto-detected)"
fi
echo ""

# Capture test baseline before implementation begins (skip during plan-only mode)
if [[ "$PLAN_MODE" == false ]]; then
  if [[ -f "./check-tests" ]]; then
    echo "Capturing test baseline before implementation..."
    if ! ./check-tests 2>&1; then
      echo ""
      echo "⚠  Unexpected test failures exist before implementation starts."
      echo "   Run /fix-baseline in Claude Code to resolve pre-existing failures first,"
      echo "   or add them to $KNOWN_FILE if they are acceptable."
      echo "   Continuing anyway — the implementor will see these in their test run."
      echo ""
    else
      echo ""
    fi
  fi
fi


case "$TOOL" in
  codex)
    # AGENTS.md is auto-loaded by Codex; prompt also explicitly requires AGENT.md + CODING.md
    # to guarantee both are loaded regardless of auto-discovery behavior.
    # Runs in interactive mode (no exec/--full-auto) so sessions can be continued
    # by typing 'continue' rather than restarting from scratch after a timeout.
    CONTEXT_PREFIX="First read AGENT.md and CODING.md in full. Confirm you have read both before making any changes. "
    CODEX_ARGS=()
    if [[ -n "$MODEL" ]]; then
      CODEX_ARGS+=(-m "$MODEL")
    fi

    if [[ "$PLAN_MODE" == true ]]; then
      PROMPT="${CONTEXT_PREFIX}Read $SPEC_FILE. Write an implementation plan to $PLAN_FILE using the Plan Mode section format in AGENT.md. Do not write any code. After writing the plan, output a summary."
    elif [[ "$HAS_APPROVED_PLAN" == true ]]; then
      PROMPT="${CONTEXT_PREFIX}The approved plan in $APPROVED_PLAN_FILE has been reviewed and approved by Claude and the user. Check $PROGRESS_FILE for a progress log — if present, read the completed files to confirm their state and continue from where the previous session left off; otherwise start fresh. Maintain $PROGRESS_FILE throughout: append a progress entry after each file. After all files are implemented, run '$TEST_CMD' and fix any failing tests (run again to confirm all pass). List all files changed and paste the final test output when done."
    else
      PROMPT="${CONTEXT_PREFIX}Implement $SPEC_FILE. Maintain $PROGRESS_FILE throughout: append a progress entry after completing each file. After all files are implemented, run '$TEST_CMD' and fix any failing tests (run again to confirm all pass). List all files changed and paste the final test output when done."
    fi
    echo "Running: codex (interactive)${MODEL:+ (model: $MODEL)}"
    echo "NOTE: Codex will process the initial message then stay interactive."
    echo "      Type 'continue' after each response to proceed with remaining files."
    echo ""
    codex "${CODEX_ARGS[@]}" "$PROMPT"
    ;;

  gemini)
    # AGENT.md and CODING.md are auto-loaded via .gemini/settings.json
    if [[ "$PLAN_MODE" == true ]]; then
      PROMPT="Read $SPEC_FILE. Write an implementation plan to $PLAN_FILE using the Plan Mode section format in AGENT.md. Do not write any code. After writing the plan, output a summary and wait for my approval. Type \"approved\" to proceed with implementation."
    elif [[ "$HAS_APPROVED_PLAN" == true ]]; then
      PROMPT="The approved plan in $APPROVED_PLAN_FILE has been reviewed and approved by Claude and the user. Check $PROGRESS_FILE for a progress log — if present, read the completed files to confirm their state and continue from where the previous session left off; otherwise start fresh. Maintain $PROGRESS_FILE throughout: append a progress entry after each file. After all files are implemented, run '$TEST_CMD' and fix any failing tests (run again to confirm all pass). List all files changed and paste the final test output when done."
    else
      PROMPT="Implement $SPEC_FILE. Maintain $PROGRESS_FILE throughout: append a progress entry after completing each file. After all files are implemented, run '$TEST_CMD' and fix any failing tests (run again to confirm all pass). List all files changed and paste the final test output when done."
    fi
    echo "Running: gemini \"$PROMPT\""
    echo ""
    gemini "$PROMPT"
    ;;

  aider)
    # AGENT.md and CODING.md are auto-loaded via .aider.conf.yml
    # --yes: auto-accept all file-addition prompts (no interactive confirmations)
    CMD_ARGS=(--yes)
    if [[ -n "$MODEL" ]]; then
      CMD_ARGS+=(--model "$MODEL")
    fi

    if [[ "$PLAN_MODE" == true ]]; then
      # Plan mode: write plan file only, no code changes.
      # Inline the spec content in the message rather than using --read so that
      # aider does not recognise the spec's file paths as repo files and prompt
      # to add them to the chat (which interferes with the plan-file write).
      touch "$PLAN_FILE"
      CMD_ARGS+=("$PLAN_FILE")
      CMD_ARGS+=(--message "$(printf 'Feature spec for %s:\n\n%s\n\nTask: Write an implementation plan to %s following the Plan Mode format in AGENT.md.\nRules:\n- Write ONLY to %s\n- Do NOT add any other files to the chat\n- Do NOT write any implementation code\n- After writing the plan file, print a one-paragraph summary and stop' \
        "$SPEC_ID" "$(< "$SPEC_FILE")" "$PLAN_FILE" "$PLAN_FILE")")
      echo "Running: aider (plan mode — spec inlined, writing to $PLAN_FILE)"
      echo ""
      aider "${CMD_ARGS[@]}"
    else
      # Implementation mode: interactive session
      CMD_ARGS+=(--read "$SPEC_FILE")

      # Load optional reference file for context (e.g. a representative test file)
      if [[ -n "$AIDER_REFERENCE_FILE" ]] && [[ -f "$AIDER_REFERENCE_FILE" ]]; then
        CMD_ARGS+=(--read "$AIDER_REFERENCE_FILE")
      fi

      # Extract all backtick-quoted paths matching SPEC_FILE_PATTERN from the spec
      FILES=$(grep -oP "\`($SPEC_FILE_PATTERN)/[^\`]+\`" "$SPEC_FILE" | tr -d '`' | sort -u)

      if [[ -z "$FILES" ]]; then
        echo "Error: No file paths matching '$SPEC_FILE_PATTERN' found in spec."
        echo "Check Files to Modify, New Files, and Tests to Write sections use backtick-quoted paths."
        exit 1
      fi

      echo "Files from spec:"
      echo "$FILES" | sed 's/^/  /'
      echo ""

      # Pre-create any files that don't exist yet so aider can open them without prompting
      while IFS= read -r f; do
        if [[ ! -f "$f" ]]; then
          mkdir -p "$(dirname "$f")"
          touch "$f"
          echo "  Created (empty): $f"
        fi
      done <<< "$FILES"
      touch "$PROGRESS_FILE"
      echo ""

      while IFS= read -r f; do
        CMD_ARGS+=("$f")
      done <<< "$FILES"

      # Progress file is always editable so aider can write to it
      CMD_ARGS+=("$PROGRESS_FILE")

      # Build the implementation prompt — sent as --message to kick off the session.
      # Aider processes the message and then stays in interactive mode.
      # Type 'continue' after each response to proceed with remaining files.
      if [[ "$HAS_APPROVED_PLAN" == true ]]; then
        IMPL_PROMPT=$(printf 'The following implementation plan has been reviewed and approved by Claude and the user. Follow it exactly. Proceed directly — do not ask for confirmation.\n\n---BEGIN APPROVED PLAN---\n%s\n---END APPROVED PLAN---\n\nCheck %s for a progress log — if present, read the completed files to confirm their state and continue from where the previous session left off; otherwise start fresh. Maintain %s throughout: append a progress entry after each file. After all files are implemented, run '"'"'%s'"'"' and fix any failing tests (run again to confirm all pass). List all files changed and paste the final test output when done.' \
          "$(< "$APPROVED_PLAN_FILE")" "$PROGRESS_FILE" "$PROGRESS_FILE" "$TEST_CMD")
      else
        IMPL_PROMPT=$(printf 'Implement the spec provided in context (read-only). Maintain %s throughout: append a progress entry after completing each file. After all files are implemented, run '"'"'%s'"'"' and fix any failing tests (run again to confirm all pass). List all files changed and paste the final test output when done.' \
          "$PROGRESS_FILE" "$TEST_CMD")
      fi

      CMD_ARGS+=(--message "$IMPL_PROMPT")

      echo "NOTE: Aider will process the initial message then stay interactive."
      echo "      Type 'continue' after each response to proceed with remaining files."
      echo ""
      echo "Running: aider (interactive, initial message set)"
      echo ""
      aider "${CMD_ARGS[@]}"
    fi
    ;;

  *)
    echo "Unknown tool: $TOOL"
    echo "Use --tool codex, gemini, or aider"
    exit 1
    ;;
esac
